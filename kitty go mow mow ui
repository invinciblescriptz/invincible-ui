-- Input handling for toggle key
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

local binding = false
local function toggleGui()
    if script.Parent and not binding then
        script.Parent.Enabled = not script.Parent.Enabled
    end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == a.toggle_key then
        toggleGui()
    end
end)

-- Example of resize functionality
local function resizeWindow(window, newSize)
    if not window or not window.Parent then return end
    window:TweenSize(UDim2.new(0, newSize.X, 0, newSize.Y), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
end

