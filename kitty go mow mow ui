end

-- Ripple Effect
local function Ripple(parent, x, y)
    local ripple = Instance.new("Frame")
    ripple.Name = "Ripple"
    ripple.Parent = parent
    ripple.BackgroundColor3 = Color3.new(1, 1, 1)
    ripple.BackgroundTransparency = 0.6
    ripple.BorderSizePixel = 0
    ripple.ZIndex = 100
    ripple.Position = UDim2.new(0, x - parent.AbsolutePosition.X, 0, y - parent.AbsolutePosition.Y)
    ripple.Size = UDim2.new(0, 0, 0, 0)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = ripple

    local size = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.5
    Tween(ripple, {Size = UDim2.new(0, size, 0, size), BackgroundTransparency = 1, Position = UDim2.new(0.5, -size/2, 0.5, -size/2)}):Play()
    task.delay(Config.TweenTime + 0.1, function() ripple:Destroy() end)
end

