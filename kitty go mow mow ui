-- Settings
local Settings = {
    main_color = Color3.fromRGB(41, 74, 122),
    min_size = Vector2.new(400, 300),
    toggle_key = Enum.KeyCode.RightShift,
    can_resize = true
}

-- Clear old GUI
local CoreGui = game:GetService("CoreGui")
local oldGui = CoreGui:FindFirstChild("imgui")
if oldGui then oldGui:Destroy() end

-- Services
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

-- Create main GUI
local GUI = Instance.new("ScreenGui")
GUI.Name = "imgui"
GUI.Parent = CoreGui or gethui()

-- Prefabs container
local Prefabs = Instance.new("Frame")
Prefabs.Name = "Prefabs"
Prefabs.Parent = GUI
Prefabs.BackgroundTransparency = 1
Prefabs.Size = UDim2.new(0, 100, 0, 100)
Prefabs.Visible = false

-- Utility Functions
local Connections = {}
local function TrackConnection(conn)
    table.insert(Connections, conn)
    return conn
end
local function DisconnectAll()
    for _, conn in ipairs(Connections) do
        if conn.Connected then conn:Disconnect() end
    end
    Connections = {}
end

-- Tween utility
local function Tween(target, properties, duration)
    duration = duration or 0.1
    if duration == 0 then
        for prop, val in pairs(properties) do
            target[prop] = val
        end
        return
    end
    local info = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(target, info, properties)
    tween:Play()
    return tween
end

-- Gradient utility
local function ApplyGradient(instance, colors, rotation)
    rotation = rotation or 0
    if instance:FindFirstChild("UIGradient") then instance.UIGradient:Destroy() end
    if typeof(colors) == "Color3" then colors = {colors} end
    if not colors or #colors == 0 then return end
    if #colors == 1 then
        if instance:IsA("ImageLabel") or instance:IsA("ImageButton") then
            instance.ImageColor3 = colors[1]
        else
            instance.BackgroundColor3 = colors[1]
        end
        return
    end
    local grad = Instance.new("UIGradient")
    grad.Parent = instance
    grad.Rotation = rotation
    local keypoints = {}
    if #colors == 2 then
        keypoints = {ColorSequenceKeypoint.new(0, colors[1]), ColorSequenceKeypoint.new(1, colors[2])}
    elseif #colors >= 3 then
        keypoints = {ColorSequenceKeypoint.new(0, colors[1]), ColorSequenceKeypoint.new(0.5, colors[2]), ColorSequenceKeypoint.new(1, colors[3])}
    end
    grad.Color = ColorSequence.new(keypoints)
    if instance:IsA("ImageLabel") or instance:IsA("ImageButton") then
        instance.ImageColor3 = Color3.new(1, 1, 1)
    else
        instance.BackgroundColor3 = Color3.new(1, 1, 1)
    end
end

-- RGB to HSV
local function RGBtoHSV(r, g, b)
    r, g, b = r / 255, g / 255, b / 255
    local maxc, minc = math.max(r, g, b), math.min(r, g, b)
    local h, s, v = 0, 0, maxc
    local delta = maxc - minc
    s = maxc == 0 and 0 or delta / maxc
    if delta == 0 then
        h = 0
    elseif maxc == r then
        h = (g - b) / delta % 6
    elseif maxc == g then
        h = (b - r) / delta + 2
    else
        h = (r - g) / delta + 4
    end
    h = h / 6
    return h, s, v
end

-- Mouse helper
local function MousePos()
    return Vector2.new(UserInputService:GetMouseLocation().X + 1, UserInputService:GetMouseLocation().Y - 35)
end

-- Ripple effect
local function Ripple(parent, x, y)
    task.spawn(function()
        parent.ClipsDescendants = true
        local circle = Prefabs:FindFirstChild("Circle"):Clone()
        circle.Parent = parent
        circle.ZIndex = 1000
        local offsetX = x - circle.AbsolutePosition.X
        local offsetY = y - circle.AbsolutePosition.Y
        circle.Position = UDim2.new(0, offsetX, 0, offsetY)
        local size = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.5
        circle:TweenSizeAndPosition(UDim2.new(0, size, 0, size), UDim2.new(0.5, -size/2, 0.5, -size/2), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.5, false)
        Tween(circle, {ImageTransparency = 1}, 0.5)
        task.wait(0.5)
        circle:Destroy()
    end)
end

-- Toggle GUI visibility
TrackConnection(UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Settings.toggle_key and not gameProcessed then
        GUI.Enabled = not GUI.Enabled
    end
end))

-- Windows manager
local WindowsManager = {
    windows = {},
    count = 0
}

function WindowsManager:AddWindow(title, options)
    self.count = self.count + 1
    title = tostring(title or "New Window")
    options = typeof(options) == "table" and options or Settings
    options.tween_time = options.tween_time or 0.1
    options.title_bar = options.title_bar or {Settings.main_color}
    if typeof(options.title_bar) == "Color3" then options.title_bar = {options.title_bar} end
    options.title_bar_transparency = options.title_bar_transparency or 0
    options.background = options.background or {Color3.new(0.08, 0.09, 0.1)}
    if typeof(options.background) == "Color3" then options.background = {options.background} end
    options.background_transparency = options.background_transparency or 0.1
    if not options.main_color then options.main_color = options.title_bar[1] end

    -- Clone Window prefab
    local win = Prefabs:FindFirstChild("Window"):Clone()
    win.Parent = GUI
    win.Size = UDim2.new(0, options.min_size.X, 0, options.min_size.Y)
    win.ZIndex = win.ZIndex + self.count * 10
    win:FindFirstChild("Title").Text = title

    -- Apply title bar
    local bar = win:FindFirstChild("Bar")
    ApplyGradient(bar, options.title_bar, 0)
    bar.BackgroundTransparency = options.title_bar_transparency

    -- Apply background
    ApplyGradient(win, options.background, 45)
    win.ImageTransparency = options.background_transparency

    -- Add to manager
    self.windows[title] = win
    return win
end

return WindowsManager

