-- Create a function to add tab buttons
local function AddTabButton(name)
    local btn = Instance.new("TextButton")
    btn.Parent = tabButtonsContainer
    btn.Text = name
    btn.Size = UDim2.new(0, 80, 0, 20)
    btn.BackgroundColor3 = a.main_color
    btn.Font = Enum.Font.FredokaOne
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 14
    btn.BorderSizePixel = 0
    return btn
end

-- Toggle function for tabs
local function ToggleTabs()
    local isVisible = tabSelection.Visible
    tabSelection.Visible = not isVisible
end

-- Bind toggle to the RightShift key
local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == a.toggle_key then
        ToggleTabs()
    end
end)

-- Toggle window visibility with the toggle button (use window.Image as the icon)
toggleButton.MouseButton1Click:Connect(function()
    window.Visible = not window.Visible
end)

-- Initialize window as visible (open with the image)
window.Visible = true

